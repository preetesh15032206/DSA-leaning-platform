{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profile documents"
    },
    "/users/{userId}/completedProblems/{problemId}": {
      "schema": {
        "type": "object",
        "properties": {
          "completed": { "type": "boolean" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Tracking individual problem completion status"
    },
    "/users/{userId}/settings/schedule": {
      "schema": {
        "type": "object",
        "properties": {
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" }
        }
      },
      "description": "User specific learning plan schedule"
    }
  }
}
